# Frontend (Vite)
# Local dev + cloud API: ดู .env.development
# Deploy frontend บน /farmsim/: ใช้ .env.production

# Backend API (ถ้าว่าง = ใช้ /api บนโดเมนเดียวกัน หรือ proxy ตอน dev)
# ตัวอย่าง cloud: https://znix.online/farmsim/api
VITE_API_BASE_URL=https://znix.online/farmsim/api

# URL สำหรับ QR Code / มือถือ join เกม
# Local: http://192.168.1.10:5173
VITE_PUBLIC_BASE_URL=

# Path ตอน build production (subdirectory)
# VITE_BASE_PATH=/farmsim/
