{
  "framework": "vite",
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "cd frontend && VITE_BASE_PATH=/ VITE_API_BASE_URL=/api npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://znix.online/farmsim/api/:path*" },
    { "source": "/((?!assets/|resource/|favicon\\.svg|icons\\.svg).*)", "destination": "/index.html" }
  ]
}
